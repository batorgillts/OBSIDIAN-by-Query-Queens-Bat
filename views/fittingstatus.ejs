<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="shows-page">
  <h1 class="page-title">OBSIDIAN</h1>
  <h2 class="page-subtitle">Fitting</h2>
  <%- include('partials/flash') %>
  <form class="form-container" action="/fittingstatus" method="POST">
    <input type="hidden" name="show_id" value="<%= show_id || '' %>"/>
    <div class="form-group"><label>Fitting ID</label><input type="number" name="fitting_id" placeholder="Enter Fitting ID" required/></div>
    <div class="form-group"><label>Look ID</label><input type="number" name="look_id" placeholder="Enter Look ID" required/></div>
    <div class="form-group"><label>Model ID</label><input type="number" name="model_id" placeholder="Enter the Model ID" required/></div>
    <div class="form-group"><label>New Status</label><input type="text" name="new_status" placeholder="Enter New Status" required/></div>
    <button type="submit" class="btn btn-dark" style="width:100%">Change Status</button>
  </form>
</div>
</body></html>
