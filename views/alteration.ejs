<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="table-page">
  <h1 class="page-title">OBSIDIAN</h1>
  <h2 class="page-subtitle">Alteration</h2>
  <%- include('partials/flash') %>
  <div class="table-wrapper">
    <table>
      <thead>
        <tr><th>Alteration ID</th><th>Item ID</th><th>Fitting ID</th><th>Alteration Type</th><th>Date Needed By</th><th>Status</th></tr>
      </thead>
      <tbody>
        <% alterations.forEach(a => { %>
          <tr>
            <td><%= a.alteration_id %></td><td><%= a.item_id %></td><td><%= a.fitting_id %></td>
            <td><%= a.alteration_type %></td>
            <td><%= a.date_needed_by ? new Date(a.date_needed_by).toLocaleDateString() : '' %></td>
            <td><%= a.alteration_status %></td>
          </tr>
        <% }) %>
        <% if (!alterations.length) { %><tr><td colspan="6" style="text-align:center;color:#888">No alterations found.</td></tr><% } %>
      </tbody>
    </table>
  </div>
  <div class="btn-group">
    <a href="/alterationadd<%= show_id ? `?show_id=${show_id}` : '' %>" class="btn btn-dark">+ Add New Alteration</a>
    <a href="/alterationdelete<%= show_id ? `?show_id=${show_id}` : '' %>" class="btn btn-dark">- Delete an Alteration</a>
    <a href="/alterationstatus<%= show_id ? `?show_id=${show_id}` : '' %>" class="btn btn-dark">Change Status</a>
    <% if (show_id) { %><a href="/mymenudetail/<%= show_id %>" class="btn btn-outline">&#8592; Back</a><% } %>
  </div>
</div>
<img class="page-wm" src="https://images.unsplash.com/photo-1585421514284-efb74c2b69ba?w=500&q=60" alt=""/>
</body></html>
