<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="table-page">
  <h1 class="page-title">OBSIDIAN</h1>
  <h2 class="page-subtitle">Item</h2>
  <%- include('partials/flash') %>
  <div class="table-wrapper">
    <table>
      <thead>
        <tr><th>Item ID</th><th>Location ID</th><th>Collection ID</th><th>Category</th><th>Description</th><th>Version</th><th>Size</th><th>Condition</th></tr>
      </thead>
      <tbody>
        <% items.forEach(i => { %>
          <tr><td><%= i.item_id %></td><td><%= i.location_id %></td><td><%= i.collection_id %></td><td><%= i.item_category %></td><td><%= i.item_description %></td><td><%= i.item_version %></td><td><%= i.item_size %></td><td><%= i.item_condition %></td></tr>
        <% }) %>
        <% if (!items.length) { %><tr><td colspan="8" style="text-align:center;color:#888">No items found.</td></tr><% } %>
      </tbody>
    </table>
  </div>
  <div class="btn-group">
    <a href="/itemadd<%= show_id ? `?show_id=${show_id}` : '' %>" class="btn btn-dark">+ Add Item</a>
    <a href="/itemdelete<%= show_id ? `?show_id=${show_id}` : '' %>" class="btn btn-dark">- Delete Item</a>
    <% if (show_id) { %><a href="/mymenudetail/<%= show_id %>" class="btn btn-outline">&#8592; Back</a><% } %>
  </div>
</div>
</body></html>
